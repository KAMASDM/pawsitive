rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Pet posts - authenticated users can upload, anyone can read
    match /petPosts/{petId}/{fileName} {
      allow read: true;
      allow write: if request.auth != null;
    }
    
    // Pet images - authenticated users can upload, anyone can read
    match /petImages/{userId}/{fileName} {
      allow read: true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // User avatars - authenticated users can upload their own, anyone can read
    match /avatars/{userId}/{fileName} {
      allow read: true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Lost pets - authenticated users can upload, anyone can read
    match /lostPets/{fileName} {
      allow read: true;
      allow write: if request.auth != null;
    }
    
    // Found pets - authenticated users can upload, anyone can read
    match /foundPets/{fileName} {
      allow read: true;
      allow write: if request.auth != null;
    }

    // Challenge entries - authenticated users upload to their own folder
    match /challenge-entries/{challengeId}/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Vendor vetting documents - owner uploads, commerce admin reviews
    match /vendor-documents/{userId}/{documentType}/{fileName} {
      allow read: if request.auth != null && (
        request.auth.uid == userId ||
        request.auth.token.email == "anantsoftcomputing@gmail.com"
      );
      allow write: if request.auth != null &&
        request.auth.uid == userId &&
        request.resource.size < 8 * 1024 * 1024 &&
        request.resource.contentType.matches("application/pdf|image/jpeg|image/png|image/webp");
    }

    // Default deny all other paths
    match /{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
