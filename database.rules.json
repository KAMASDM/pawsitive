{
  "rules": {
    "users": {
      "$userId": {
        ".read": "auth != null",
        ".write": "auth != null && auth.uid == $userId"
      }
    },
    "petSlugs": {
      "$slug": {
        ".read": "true",
        ".write": "auth != null"
      }
    },
    "userPets": {
      ".read": "auth != null",
      "$userId": {
        ".read": "true",
        "$petId": {
          ".write": "auth != null && auth.uid == $userId"
        }
      }
    },
    "petPosts": {
      "$petId": {
        ".read": "true",
        ".write": "auth != null",
        "$postId": {
          ".validate": "newData.hasChildren(['mediaUrl', 'mediaType', 'timestamp'])"
        }
      }
    },
    "petEvents": {
      "$petId": {
        ".read": "true",
        ".write": "auth != null",
        "$eventId": {
          ".validate": "newData.hasChildren(['title', 'date', 'type', 'timestamp'])"
        }
      }
    },
    "petProfiles": {
      "$petId": {
        ".read": "true",
        ".write": "auth != null"
      }
    },
    "matingRequests": {
      "sent": {
        "$userId": {
          ".read": "auth != null && auth.uid == $userId",
          ".write": "auth != null && auth.uid == $userId"
        }
      },
      "received": {
        "$userId": {
          ".read": "auth != null && auth.uid == $userId",
          ".write": "auth != null && auth.uid == $userId"
        }
      }
    },
    "adoptionRequests": {
      "$requestId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "userResources": {
      "$userId": {
        ".read": "auth != null && auth.uid == $userId",
        ".write": "auth != null && auth.uid == $userId"
      }
    },
    "conversations": {
      ".read": "auth != null",
      "$conversationId": {
        ".write": "auth != null"
      }
    },
    "resources": {
      "$placeId": {
        "comments": {
          ".read": "true",
          ".write": "auth != null"
        }
      }
    },
    "userComments": {
      "$userId": {
        ".read": "auth != null && auth.uid == $userId",
        ".write": "auth != null && auth.uid == $userId"
      }
    },
    "comments": {
      "$resourceId": {
        ".read": "true",
        ".write": "auth != null"
      }
    },
    "taggedPlaces": {
      ".read": "true",
      ".write": "auth != null",
      "$placeId": {
        ".validate": "newData.hasChildren(['placeName', 'location', 'geohash', 'isPetFriendly', 'comment', 'userId', 'userEmail', 'timestamp', 'createdAt'])"
      }
    },
    "notifications": {
      "$userId": {
        ".read": "auth != null && auth.uid == $userId",
        ".write": "auth != null"
      }
    },
    "broadcastNotifications": {
      ".read": "auth != null",
      ".write": "false"
    },
    "notificationReads": {
      "$userId": {
        ".read": "auth != null && auth.uid == $userId",
        ".write": "auth != null && auth.uid == $userId"
      }
    },
    "vendorApplications": {
      ".read": "auth != null && auth.token.email == 'anantsoftcomputing@gmail.com'",
      "$userId": {
        ".read": "auth != null && auth.uid == $userId",
        ".write": "auth != null && (auth.token.email == 'anantsoftcomputing@gmail.com' || (auth.uid == $userId && (!newData.child('status').exists() || newData.child('status').val() == 'pending')))"
      }
    },
    "vendorApprovals": {
      ".read": "auth != null && auth.token.email == 'anantsoftcomputing@gmail.com'",
      "$userId": {
        ".read": "auth != null && auth.uid == $userId",
        ".write": "auth != null && auth.token.email == 'anantsoftcomputing@gmail.com'"
      }
    },
    "vendorDocuments": {
      "$vendorId": {
        ".read": "auth != null && (auth.token.role == 'admin' || auth.token.vendorId == $vendorId)",
        "$documentType": {
          ".write": "auth != null && (auth.token.role == 'admin' || auth.token.vendorId == $vendorId)"
        }
      }
    },
    "vendorStores": {
      ".read": "true",
      "$storeId": {
        ".write": "auth != null && root.child('vendorApprovals').child(auth.uid).child('approved').val() == true && (!data.exists() || data.child('ownerId').val() == auth.uid || newData.child('ownerId').val() == auth.uid)"
      }
    },
    "vendorStoreSlugs": {
      ".read": "true",
      "$slug": {
        ".write": "auth != null && root.child('vendorApprovals').child(auth.uid).child('approved').val() == true && (!data.exists() || data.child('ownerId').val() == auth.uid)"
      }
    },
    "vendorProducts": {
      ".read": "true",
      "$storeId": {
        "$productId": {
          ".write": "auth != null && root.child('vendorStores').child($storeId).child('ownerId').val() == auth.uid"
        }
      }
    },
    "buyerOrders": {
      "$userId": {
        ".read": "auth != null && auth.uid == $userId",
        ".write": "auth != null && auth.uid == $userId"
      }
    },
    "vendorOrders": {
      "$storeId": {
        ".read": "auth != null && root.child('vendorStores').child($storeId).child('ownerId').val() == auth.uid",
        "$orderId": {
          ".write": "auth != null && (root.child('vendorStores').child($storeId).child('ownerId').val() == auth.uid || newData.child('buyerId').val() == auth.uid)"
        }
      }
    },
    "lostPets": {
      ".read": "true",
      "$reportId": {
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['petType', 'petName', 'lastSeenDate', 'lastSeenLocation', 'userId', 'status', 'createdAt'])"
      }
    },
    "foundPets": {
      ".read": "true",
      "$reportId": {
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['petType', 'foundDate', 'foundLocation', 'userId', 'status', 'createdAt'])"
      }
    }
  }
}
