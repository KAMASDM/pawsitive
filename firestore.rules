rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -----------------------------------------------------------------------
    // HELPER FUNCTIONS
    // -----------------------------------------------------------------------
    function isAuthed() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isAuthed() && request.auth.uid == uid;
    }
    function isAdmin() {
      return isAuthed() && request.auth.token.role == "admin";
    }
    function ownsVendor(vendorId) {
      return isAuthed() && request.auth.token.vendorId == vendorId;
    }
    function vendorProtectedFields() {
      return ["status", "statusHistory", "approvedAt", "approvedBy", "ownerUid", "productCount", "orderCount", "rating"];
    }

    // -----------------------------------------------------------------------
    // RESOURCES / COMMENTS  (legacy)
    // -----------------------------------------------------------------------
    match /resources/{resourceId}/comments/{comment} {
      allow read: if true;
      allow write: if isAuthed();
    }

    // -----------------------------------------------------------------------
    // USERS — per-user sub-collections
    // -----------------------------------------------------------------------
    match /users/{userId}/comments/{comment} {
      allow read, write: if isOwner(userId);
    }
    match /users/{userId}/quizHistory/{weekId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);
    }
    match /users/{userId}/quizStats/{doc} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);
    }
    match /users/{userId}/challengeHistory/{challengeId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);
    }
    match /users/{userId}/addresses/{addressId} {
      allow read, write: if isOwner(userId);
    }

    // -----------------------------------------------------------------------
    // COMMERCE USERS / VENDORS
    // -----------------------------------------------------------------------
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if false; // Cloud Functions / Admin SDK only
      allow update: if (isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(["role", "vendorId", "createdAt"]))
        || isAdmin();
      allow delete: if isAdmin();
    }

    match /vendors/{vendorId} {
      allow read: if isAdmin() || ownsVendor(vendorId);
      allow create: if false; // requestVendorRole callable only
      allow update: if isAdmin()
        || (ownsVendor(vendorId)
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny(vendorProtectedFields())
          && resource.data.status in ["pending", "documentation_required", "rejected"]);
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if resource.data.status == "active" || isAdmin() || ownsVendor(resource.data.vendorId);
      allow write: if false; // Phase C will open vendor product writes with approved-vendor checks.
    }

    match /vendorStoreSlugs/{slug} {
      allow read: if true;
      allow write: if false;
    }

    match /productSlugs/{slug} {
      allow read: if true;
      allow write: if false;
    }

    match /carts/{cartId} {
      allow read: if isAdmin() || isOwner(cartId) || (isAuthed() && resource.data.userId == request.auth.uid);
      allow write: if isOwner(cartId) && request.resource.data.userId == request.auth.uid;
    }

    match /coupons/{code} {
      allow read: if isAuthed();
      allow write: if false; // commerce-manage-coupon only
    }

    match /reviews/{reviewId} {
      allow read: if resource.data.status == "published" || isAdmin();
      allow write: if false; // commerce-save-review only
    }

    match /orders/{orderId} {
      allow read: if isAdmin()
        || (isAuthed() && resource.data.userId == request.auth.uid)
        || (isAuthed() && resource.data.vendorIds.hasAny([request.auth.token.vendorId]));
      allow write: if false; // Cloud Functions own money/payment/order state.
      match /subOrders/{vendorId} {
        allow read: if isAdmin() || ownsVendor(vendorId);
        allow write: if false;
      }
    }

    // -----------------------------------------------------------------------
    // WEEKLY QUIZ
    // -----------------------------------------------------------------------
    match /weeklyQuiz/{quizId} {
      allow read: if true;       // public — anyone can read questions
      allow write: if false;     // only Cloud Functions write this
    }
    match /weeklyQuiz/{quizId}/leaderboard/{uid} {
      allow read: if true;
      allow write: if isOwner(uid);
    }

    // -----------------------------------------------------------------------
    // QUIZ BANK  (admin/seed only)
    // -----------------------------------------------------------------------
    match /quizBank/{doc} {
      allow read: if true;
      allow write: if false;     // only admin SDK / Cloud Functions
    }

    // -----------------------------------------------------------------------
    // CHALLENGE
    // -----------------------------------------------------------------------
    match /challenges/{challengeId} {
      allow read: if true;
      allow create: if false;    // Cloud Function only
      allow update: if false;    // Cloud Function only (entryCount, winner)
    }
    match /challenges/{challengeId}/entries/{entryId} {
      allow read: if true;
      // Authenticated user can create their own entry
      allow create: if isAuthed() && request.resource.data.uid == request.auth.uid;
      // Any authenticated user can increment voteCount (voting)
      allow update: if isAuthed()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['voteCount']);
      allow delete: if false;
    }
    match /challenges/{challengeId}/votes/{uid} {
      allow read: if true;
      // A user can cast exactly one vote (their own doc)
      allow create: if isOwner(uid);
      allow update, delete: if false;
    }

    // -----------------------------------------------------------------------
    // CHALLENGE TEMPLATES  (admin/seed only)
    // -----------------------------------------------------------------------
    match /challengeTemplates/{doc} {
      allow read: if true;
      allow write: if false;
    }

    // -----------------------------------------------------------------------
    // DEFAULT — deny everything not matched above
    // -----------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
