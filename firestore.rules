rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -----------------------------------------------------------------------
    // HELPER FUNCTIONS
    // -----------------------------------------------------------------------
    function isAuthed() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isAuthed() && request.auth.uid == uid;
    }

    // -----------------------------------------------------------------------
    // RESOURCES / COMMENTS  (legacy)
    // -----------------------------------------------------------------------
    match /resources/{resourceId}/comments/{comment} {
      allow read: if true;
      allow write: if isAuthed();
    }

    // -----------------------------------------------------------------------
    // USERS — per-user sub-collections
    // -----------------------------------------------------------------------
    match /users/{userId}/comments/{comment} {
      allow read, write: if isOwner(userId);
    }
    match /users/{userId}/quizHistory/{weekId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);
    }
    match /users/{userId}/quizStats/{doc} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);
    }
    match /users/{userId}/challengeHistory/{challengeId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);
    }

    // -----------------------------------------------------------------------
    // WEEKLY QUIZ
    // -----------------------------------------------------------------------
    match /weeklyQuiz/{quizId} {
      allow read: if true;       // public — anyone can read questions
      allow write: if false;     // only Cloud Functions write this
    }
    match /weeklyQuiz/{quizId}/leaderboard/{uid} {
      allow read: if true;
      allow write: if isOwner(uid);
    }

    // -----------------------------------------------------------------------
    // QUIZ BANK  (admin/seed only)
    // -----------------------------------------------------------------------
    match /quizBank/{doc} {
      allow read: if true;
      allow write: if false;     // only admin SDK / Cloud Functions
    }

    // -----------------------------------------------------------------------
    // CHALLENGE
    // -----------------------------------------------------------------------
    match /challenges/{challengeId} {
      allow read: if true;
      allow create: if false;    // Cloud Function only
      allow update: if false;    // Cloud Function only (entryCount, winner)
    }
    match /challenges/{challengeId}/entries/{entryId} {
      allow read: if true;
      // Authenticated user can create their own entry
      allow create: if isAuthed() && request.resource.data.uid == request.auth.uid;
      // Any authenticated user can increment voteCount (voting)
      allow update: if isAuthed()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['voteCount']);
      allow delete: if false;
    }
    match /challenges/{challengeId}/votes/{uid} {
      allow read: if true;
      // A user can cast exactly one vote (their own doc)
      allow create: if isOwner(uid);
      allow update, delete: if false;
    }

    // -----------------------------------------------------------------------
    // CHALLENGE TEMPLATES  (admin/seed only)
    // -----------------------------------------------------------------------
    match /challengeTemplates/{doc} {
      allow read: if true;
      allow write: if false;
    }

    // -----------------------------------------------------------------------
    // DEFAULT — deny everything not matched above
    // -----------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
